+    // Scribble by SELF-CROSSING first: a stroke that crosses itself
+    // mid-path is a scribble whatever its corner count, and must be
+    // decided before the nearly-closed rescue below.
+    if (f.selfIntersections >= params.scribbleMinIntersections) {
         result.shape = StrokeShape::Scribble;
         result.confidence = 0.8f;
         return result;
     }
+
+    // NEARLY-CLOSED RESCUE. A hand-drawn quad that does not quite meet at
+    // the seam is still a quad, but the branches below would call it a
+    // Scribble (>= 4 corners -> DissolveEdge, "Dissolve no change") or drop
+    // it to Unknown ("Not recognized") when the open stroke shows only 3
+    // corners because the seam corner never registers. Measured on device:
+    // real quad strokes land at a gap ratio of ~0.21 with 3 corners.
+    //
+    // Ordered AFTER grid, cross and self-crossing scribble: those are
+    // real gestures with their own structure and must keep priority (an
+    // earlier ordering here reclassified every grid stroke as a quad).
+    // This rescues only strokes that would otherwise fall through to
+    // Scribble-by-corners or Unknown. Confidence is reduced
+    // (0.65) so the chip still offers alternatives: the user can pick
+    // another interpretation when this guesses wrong.
+    if (f.straightness < params.nearlyClosedFraction && f.corners >= 3 &&
