+
+// Self-intersections EXCLUDING the seam: crossings between a leading
+// segment and a trailing segment, which is what closing a hand-drawn loop
+// produces when the pen overshoots the start.
+//
+// Why this exists: a closed quad only classifies as ClosedLoop when it has
+// zero self-intersections, and overshooting the join is what a human hand
+// does drawing a square. Counting that overshoot demoted the stroke to
+// Lasso -> hideRegion, so drawing a quad hid faces instead. `countSelfIntersections`
+// exempts only the exact first/last segment pair, which is one segment's
+// worth of tolerance; a real overshoot crosses several segments in.
+//
+// Crossings anywhere else still count, so a genuine scribble (which
+// crosses itself mid-stroke) is unaffected.
+inline int countSelfIntersectionsIgnoringSeam(const std::vector<Vec2>& p,
+                                              int seamSegments) {
+    const std::size_t n = p.size();
+    if (n < 2) {
+        return 0;
+    }
+    const std::size_t seam =
+        static_cast<std::size_t>(std::max(0, seamSegments));
+    const std::size_t lastSegment = n - 2;  // index of the final segment
+    int hits = 0;
+    for (std::size_t i = 0; i + 1 < n; ++i) {
+        for (std::size_t j = i + 2; j + 1 < n; ++j) {
+            const bool leading = i <= seam;
+            const bool trailing = j + seam >= lastSegment;
+            if (leading && trailing) {
+                continue;  // seam artifact, not a scribble signal
             }
             if (segmentsCross(p[i], p[i + 1], p[j], p[j + 1])) {
                 ++hits;
@@ -550,6 +603,11 @@
