+    // is an artifact of closing the loop, not evidence of scribbling.
+    const int seamTolerantIntersections =
+        countSelfIntersectionsIgnoringSeam(pts, params.seamIgnoreSegments);
 
     const ShapeFeatures& f = result.features;
     if (f.closed) {
