+        result.corners = quadCorners(pts, rc, window, params.cornerRadians);
+        const float invAspect = params.aspect > 0.0f ? 1.0f / params.aspect : 1.0f;
+        for (Vec2& c : result.corners) {
+            c.x *= invAspect;
+        }
+        result.shape = StrokeShape::ClosedLoop;
