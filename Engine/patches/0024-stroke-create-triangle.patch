+// True when the stroke's seam — its start/end point — is itself a sharp
+// corner, i.e. the hand closed the polygon AT a vertex rather than mid-edge.
+// The non-wrapping corner scan never sees the seam, so this is what lets a
+// three-detected-corner stroke tell a triangle closed mid-edge (3 real
+// corners) from a quad closed at a corner (3 + the seam = 4).
+inline bool seamIsCorner(const std::vector<Vec2>& p, int window, float cornerRadians) {
+    const int n = static_cast<int>(p.size());
+    if (n < 2 * window + 1) {
+        return false;
+    }
+    const Vec2 in = p[0] - p[static_cast<std::size_t>(n - window)];
+    const Vec2 out = p[static_cast<std::size_t>(window)] - p[0];
+    const float li = len(in);
+    const float lo = len(out);
+    if (li < 1e-6f || lo < 1e-6f) {
+        return false;
+    }
+    const float cosA = std::clamp(dot2(in, out) / (li * lo), -1.0f, 1.0f);
+    return std::acos(cosA) > cornerRadians;
+}
+
+// Estimated corners of a closed-ish stroke, returning THREE for a triangle
+// and FOUR for a quad. Conservative by design: a stroke is a triangle only
+// when its corners plus the seam count to exactly three; ANY ambiguity falls
+// back to `quadCorners`, so a quad is never misread as a triangle (the safe
+// failure is a triangle read as a quad — today's behaviour, not a
+// regression). Triangle corners are returned in stroke (ring) order so the
+// shell's CreateTriangle application builds a non-self-intersecting face.
+inline std::vector<Vec2> polygonCorners(const std::vector<Vec2>& p, Vec2 centroid, int window,
+                                        float cornerRadians) {
+    const std::vector<int> detected = cornerIndices(p, window, cornerRadians);
+    const bool seam = seamIsCorner(p, window, cornerRadians);
+    const int total = static_cast<int>(detected.size()) + (seam ? 1 : 0);
+    if (total == 3 && !detected.empty()) {
+        std::vector<Vec2> corners;
+        corners.reserve(3);
+        if (seam) {
+            corners.push_back(p.front());
+        }
+        for (const int i : detected) {
+            corners.push_back(p[static_cast<std::size_t>(i)]);
+        }
+        // Reject a degenerate ring — coinciding OR near-collinear corners —
+        // and fall back to the quad estimate. The collinearity guard is what
+        // stops a FLAT closed stroke (an elongated lasso started at a pointy
+        // end registers two tips plus the seam = three "corners") from being
+        // read as a triangle: a real triangle bounds substantial area, a
+        // sliver does not. Test: area / perimeter^2, scale-free; an
+        // equilateral triangle is ~0.048, a thin sliver approaches 0.
+        const Vec2 a = corners[0];
+        const Vec2 b = corners[1];
+        const Vec2 c = corners[2];
+        const float area = 0.5f * std::fabs((b.x - a.x) * (c.y - a.y) -
+                                            (c.x - a.x) * (b.y - a.y));
+        const float perimeter = len(b - a) + len(c - b) + len(a - c);
+        const float fatness = perimeter > 1e-6f ? area / (perimeter * perimeter) : 0.0f;
+        if (fatness > 0.02f) {
+            return corners;
+        }
+    }
+    return quadCorners(p, centroid, window, cornerRadians);
+}
